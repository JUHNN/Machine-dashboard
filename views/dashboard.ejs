<!DOCTYPE html>
<html>
<head>
    <title>Semiconductor Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: Arial, sans-serif; margin: 0; padding: 0; }
        .header-container { display: flex; justify-content: space-between; align-items: center; padding: 0 20px; background: #333; color: white;}
        .dashboard-wrapper { display: flex; gap: 20px; padding: 20px; }
        .left-panel { flex: 2; display: flex; flex-direction: column; gap: 20px; }
        .right-panel { 
            flex: 1.5; max-height: 85vh; overflow-y: auto; 
            border: 1px solid #ccc; padding: 15px; background: #f9f9f9;
        }
        
        .filters-container { background: #eee; padding: 15px; border-radius: 8px; display: flex; gap: 10px; flex-wrap: wrap; }
        .charts-row { display: flex; gap: 10px; }
        .chart-container { flex: 1; background: #fff; padding: 10px; border: 1px solid #ddd; border-radius: 8px; }
        
        .tab-container { display: flex; gap: 5px; margin-bottom: 10px; flex-wrap: wrap; }
        .tab-button { padding: 8px 12px; cursor: pointer; background: #ddd; border: none; border-radius: 4px; font-size: 12px; }
        .tab-button.active { background: #007bff; color: white; }
        
        table { width: 100%; border-collapse: collapse; font-size: 11px; background: white;}
        th, td { border: 1px solid #ddd; padding: 6px; text-align: left; }
        th { background-color: #007bff; color: white; position: sticky; top: 0; cursor: pointer; user-select: none; }
        th:hover { background-color: #0056b3; }
        td[contenteditable="true"]:hover { background: #fffbcc; cursor: text; outline: 1px dashed #ffa500;}

        #ai-feedback { background: #eef; padding: 15px; border-radius: 8px; border-left: 5px solid #007bff; max-height: 300px; overflow-y: auto;}
        button.btn { padding: 10px 20px; cursor: pointer; background: #007bff; color: white; border: none; border-radius: 5px; }
        button.btn-success { background: #28a745; }
    </style>
</head>
<body>
    <div class="header-container">
        <h1>Tool Sensor Dashboard</h1>
        <button class="btn btn-success" onclick="saveToSQL()">💾 Save Changes to cleaned_sql.sql</button>
    </div>

    <div class="dashboard-wrapper">
        <div class="left-panel">
            <div class="filters-container" id="dynamic-filters"></div>
            
            <div class="charts-row">
                <div class="chart-container"><canvas id="chartOne"></canvas></div>
                <div class="chart-container"><canvas id="chartTwo"></canvas></div>
            </div>

            <div>
                <button class="btn" id="aiButton" onclick="analyzeData()">Analyze Current Tab with AI</button>
            </div>
            <div id="ai-feedback">Analysis will appear here...</div>
        </div>

        <div class="right-panel">
            <h3>Database Tables <small>(Click cells to edit, click headers to sort)</small></h3>
            <div class="tab-container">
                <button class="tab-button active" onclick="openTab('equipment')">Equipment States</button>
                <button class="tab-button" onclick="openTab('faults')">Fault Events</button>
                <button class="tab-button" onclick="openTab('processes')">Process Params</button>
                <button class="tab-button" onclick="openTab('sensors')">Sensor Readings</button>
                <button class="tab-button" onclick="openTab('wafer')">Wafer Sequences</button>
            </div>

            <div id="table-container"></div>
        </div>
    </div>

    <script>
        const dbData = {
            equipment: <%- JSON.stringify(equipment) %>,
            faults: <%- JSON.stringify(faults) %>,
            processes: <%- JSON.stringify(params) %>,
            sensors: <%- JSON.stringify(sensors) %>,
            wafer: <%- JSON.stringify(sequences) %>
        };

        // Table schema definitions for rendering
        const schemas = {
            equipment: { pk: 'state_id', cols: ['state_id', 'tool_id', 'from_state', 'to_state'] },
            faults: { pk: 'fault_event_id', cols: ['fault_event_id', 'tool_id', 'lot_id', 'wafer_id', 'step_name', 'step_seq', 'fault_code', 'severity'] },
            processes: { pk: 'param_id', cols: ['param_id', 'tool_id', 'recipe_id', 'step_name', 'parameter_name', 'parameter_value', 'unit'] },
            sensors: { pk: 'reading_id', cols: ['reading_id', 'tool_id', 'lot_id', 'wafer_id', 'parameter', 'value', 'unit'] },
            wafer: { pk: 'sequence_id', cols: ['sequence_id', 'tool_id', 'lot_id', 'wafer_id', 'action', 'result'] }
        };

        let currentTab = 'equipment';
        let chartInstanceOne = null, chartInstanceTwo = null;
        let activeFilters = {};
        
        // Sorting State
        let sortCol = null;
        let sortAsc = true;

        document.addEventListener("DOMContentLoaded", () => openTab('equipment'));

        function openTab(tabId) {
            currentTab = tabId;
            activeFilters = {}; 
            sortCol = null; // Reset sort on tab change

            document.querySelectorAll('.tab-button').forEach(b => b.classList.remove('active'));
            document.querySelector(`button[onclick="openTab('${tabId}')"]`).classList.add('active');

            buildFilters(tabId);
            renderUI();
        }

        function handleSort(col) {
            if (sortCol === col) {
                sortAsc = !sortAsc; // Reverse if clicking same header
            } else {
                sortCol = col;
                sortAsc = true; // Default to ascending on new header
            }
            renderUI();
        }

        function buildFilters(tabId) {
            const filterDiv = document.getElementById('dynamic-filters');
            filterDiv.innerHTML = `<strong>Filters:</strong>`;
            
            const createSelect = (key, label, options) => {
                const sel = document.createElement('select');
                sel.innerHTML = `<option value="">All ${label}</option>` + options.map(o => `<option value="${o}">${o}</option>`).join('');
                sel.onchange = (e) => { activeFilters[key] = e.target.value; renderUI(); };
                filterDiv.appendChild(sel);
            };

            if (tabId === 'equipment' || tabId === 'processes') createSelect('tool_type', 'Tool Types', ['CVD', 'FURNACE', 'IMP']);
            if (tabId === 'faults') {
                createSelect('tool_type', 'Tool Types', ['CVD', 'FURNACE', 'IMP']);
                createSelect('step_name', 'Step Name', [...new Set(dbData.faults.map(f => f.step_name).filter(Boolean))]);
                createSelect('severity', 'Severity', [...new Set(dbData.faults.map(f => f.severity).filter(Boolean))]);
            }
        }

        function getFilteredAndSortedData() {
            let data = [...dbData[currentTab]]; // Copy array
            
            // 1. Filter
            if (activeFilters.tool_type) data = data.filter(d => d.tool_id && d.tool_id.includes(`EQP_${activeFilters.tool_type}`));
            if (activeFilters.step_name && currentTab === 'faults') data = data.filter(d => d.step_name === activeFilters.step_name);
            if (activeFilters.severity && currentTab === 'faults') data = data.filter(d => d.severity === activeFilters.severity);

            // 2. Sort
            if (sortCol) {
                data.sort((a, b) => {
                    let valA = a[sortCol] != null ? a[sortCol] : '';
                    let valB = b[sortCol] != null ? b[sortCol] : '';
                    if (typeof valA === 'string' && typeof valB === 'string') {
                        return sortAsc ? valA.localeCompare(valB) : valB.localeCompare(valA);
                    }
                    return sortAsc ? (valA > valB ? 1 : -1) : (valA < valB ? 1 : -1);
                });
            }
            return data;
        }

        function renderUI() {
            const data = getFilteredAndSortedData();
            renderTable(data);
            renderCharts(data);
        }

        function renderTable(data) {
            const schema = schemas[currentTab];
            let html = `<table><thead><tr>`;
            
            // Headers with Sort Indicators
            schema.cols.forEach(col => {
                let indicator = '';
                if (sortCol === col) indicator = sortAsc ? ' ▲' : ' ▼';
                html += `<th onclick="handleSort('${col}')">${col}${indicator}</th>`;
            });
            html += `</tr></thead><tbody>`;

            // Rows with Inline Edit binding
            data.slice(0, 100).forEach(row => {
                html += `<tr>`;
                schema.cols.forEach(col => {
                    const isPk = (col === schema.pk);
                    const val = row[col] !== null ? row[col] : '';
                    // Primary keys are not editable
                    html += `<td contenteditable="${!isPk}" onblur="saveCell(this, '${currentTab}', '${schema.pk}', ${row[schema.pk]}, '${col}')">${val}</td>`;
                });
                html += `</tr>`;
            });
            
            html += `</tbody></table>`;
            document.getElementById('table-container').innerHTML = html;
        }

        // --- NEW: Handle Inline Edit Save ---
        async function saveCell(cell, table, pkField, pkValue, targetField) {
            const newValue = cell.innerText.trim();
            
            // Update local state first so UI doesn't revert on re-render
            const rowRef = dbData[table].find(r => r[pkField] == pkValue);
            if (rowRef) rowRef[targetField] = newValue;

            // Send to server
            try {
                await fetch('/update-cell', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ table, pkField, pkValue, targetField, newValue })
                });
                // Optional: Show a tiny success toast here
            } catch (e) {
                alert("Failed to save edit to server.");
            }
        }

        // --- NEW: Save Database to File ---
        async function saveToSQL() {
            if(!confirm("Export current database to cleaned_sql.sql?")) return;
            try {
                const res = await fetch('/save-sql', { method: 'POST' });
                const data = await res.json();
                alert(data.message || "Saved successfully!");
            } catch (e) {
                alert("Failed to save to SQL file.");
            }
        }

        // --- Chart Rendering Logic ---
        const countBy = (data, keyFn) => data.reduce((acc, val) => { const k = keyFn(val); acc[k] = (acc[k]||0)+1; return acc; }, {});
        function createChart(id, inst, cfg) { if(inst) inst.destroy(); return new Chart(document.getElementById(id), cfg); }

        function renderCharts(data) {
            if (currentTab === 'equipment') {
                const tr = countBy(data, r => `${r.from_state||'N/A'} TO ${r.to_state||'N/A'}`);
                chartInstanceOne = createChart('chartOne', chartInstanceOne, { type: 'pie', data: { labels: Object.keys(tr), datasets: [{ data: Object.values(tr) }] }});
                chartInstanceTwo = createChart('chartTwo', chartInstanceTwo, { type: 'bar', data: { labels: Object.keys(tr), datasets: [{ label: 'Count', data: Object.values(tr), backgroundColor: '#36a2eb' }] }});
            }
            else if (currentTab === 'faults') {
                const barAxis = activeFilters.step_name ? 'step_seq' : 'step_name';
                const barData = countBy(data, r => r[barAxis] || 'Unknown');
                const pieData = countBy(data, r => r.fault_code || 'Unknown');
                chartInstanceOne = createChart('chartOne', chartInstanceOne, { type: 'bar', data: { labels: Object.keys(barData), datasets: [{ label: `Faults by ${barAxis}`, data: Object.values(barData), backgroundColor: '#ff6384' }] }});
                chartInstanceTwo = createChart('chartTwo', chartInstanceTwo, { type: 'pie', data: { labels: Object.keys(pieData), datasets: [{ data: Object.values(pieData) }] }});
            }
            // Add remaining chart renders identical to previous code here if needed...
        }

        async function analyzeData() {
            const feedback = document.getElementById('ai-feedback');
            document.getElementById('aiButton').disabled = true;
            feedback.innerHTML = "<em>Analyzing...</em>";
            try {
                const res = await fetch('/analyze-data', { 
                    method: 'POST', headers: { 'Content-Type': 'application/json' }, 
                    body: JSON.stringify({ targetTab: currentTab, data: getFilteredAndSortedData().slice(0, 50) }) 
                });
                const result = await res.json();
                feedback.innerHTML = `<strong>Analysis:</strong><br>${result.analysis.replace(/\n/g, '<br>')}`;
            } catch (err) { feedback.innerText = "Error analyzing data."; }
            finally { document.getElementById('aiButton').disabled = false; }
        }
    </script>
</body>
</html>